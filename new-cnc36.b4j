' -------------------------------------------------------------
' Event Observers
' -------------------------------------------------------------
Sub RunHere_Click
	' First list available ports
	'sc.ListPorts
    
	' Then open the one you want (replace COM3 with your actual port)
	sc.OpenPort("COM37")
	statusTimer.Enabled = True
End Sub



Sub MenuBtn_Click
	Dim btn As Button = Sender
	Log("Menu: " & btn.Text)
End Sub

Sub ActionReset_Click
	Log("RESET PRESSED!")
End Sub


Sub FileAct_Click
	Dim btn As Button = Sender
	If btn.Text = "LOAD FILE" Then
		LoadAndDisplayGCodeFile
	End If
End Sub

 

Sub IconBtn_Click
    Dim btn As Button = Sender    
    Select btn.Text
        Case "RESET":  Plotter.ResetView
        Case "Z_ALL":  Plotter.TriggerZoomAll
        Case "Z_IN":   Plotter.TriggerZoomDelta(1.2)
        Case "Z_OUT":  Plotter.TriggerZoomDelta(0.8)
        Case "TOP":    Plotter.SetViewProjection("TOP")
        Case "FRONT":  Plotter.SetViewProjection("FRONT")
        Case "SIDE":   Plotter.SetViewProjection("SIDE")
        Case "ISO":    Plotter.SetViewProjection("ISO")
    End Select
End Sub



Sub LoadAndDisplayGCodeFile
	Dim fc As FileChooser
	fc.Initialize
	fc.Title = "Select G-Code File"
	fc.SetExtensionFilter("G-Code Files", Array As String("*.nc", "*.gcode", "*.txt", "*.tap"))
    
	Dim SelectedFile As String = fc.ShowOpen(MainForm)
	If SelectedFile = "" Then Return
    
	Dim LastSlash As Int = SelectedFile.LastIndexOf("\")
	Dim Folder As String = SelectedFile.SubString2(0, LastSlash)
	Dim FileNameStr As String = SelectedFile.SubString(LastSlash + 1)
    
	Plotter.LoadFileFromPath(Folder, FileNameStr)
    
	CurrentGCodeLines = Plotter.GetGCodeLines
	GcodeListView.Items.Clear
	For Each line As String In CurrentGCodeLines
		GcodeListView.Items.Add(line)
	Next
    
	UpdatingHighlight = True
	GcodeListView.SelectedIndex = 0
	GcodeListView.ScrollTo(0)
	UpdatingHighlight = False
End Sub

Sub UpdateGcodeHighlight(lineIndex As Int)
	If UpdatingHighlight Then Return
	If GcodeListView.IsInitialized = False Then Return
	If lineIndex >= 0 And lineIndex < GcodeListView.Items.Size Then
		UpdatingHighlight = True
		GcodeListView.SelectedIndex = lineIndex
		GcodeListView.ScrollTo(lineIndex)
		UpdatingHighlight = False
	End If
End Sub

Sub lstGcode_SelectedIndexChanged(Index As Int)
	If UpdatingHighlight Then Return
	If Index > -1 Then
		Plotter.SetCursorToLine(Index)
	End If
End Sub

Sub statusTimer_Tick
	'Dim cmd() As Byte = "?" & Chr(10)   ' ? + newline
	'sc.serial.Write(cmd.GetBytes("UTF8"))
	sc.Send("?\n")   ' send status query every second

End Sub

Sub SerialMessageReceived(msg As String)
	' Append incoming message to your Actual Line text box
	xCons.Text = xCons.Text & CRLF & msg
End Sub

