'================================================================================================================================
'' 5. MDI Command Entry Line & Sliders





Sub CreateMdiAndFileSection(Parent As Pane, LeftOffset As Double, TopOffset As Double, W As Double, TotalHeight As Double)
	Dim UsableHeight As Double = TotalHeight - TopOffset
	Dim TopBoxHeight As Double = UsableHeight * 0.32
    
	Dim MidPanel As Pane
	MidPanel.Initialize("")
	Parent.AddNode(MidPanel, LeftOffset + 5, TopOffset + TopBoxHeight + 10, W - 10, UsableHeight - TopBoxHeight - 15)
    
	Dim MHeight As Double = UsableHeight - TopBoxHeight - 15
    
	' Top Action Row buttons (LOAD FILE etc) Spanning fluidly
	' -------------------------------------------------------------
	' File Actions Row
	' -------------------------------------------------------------
	Dim FileActions() As String = Array As String("LOAD FILE", "EDIT FILE", "REWIND FILE", "CLOSE FILE")
	Dim ActBtnW As Double = (W - 10) / FileActions.Length

	For i = 0 To FileActions.Length - 1
		Dim btnAct As Button
		btnAct.Initialize("FileAct")
		Dim xAct As B4XView = btnAct
		xAct.Text = FileActions(i)
		xAct.Font = fx.CreateFont("Arial Narrow", 11, True, False)
		xAct.Color = xui.Color_White
		btnAct.Style = "-fx-border-color: #A0A0A0;"
		'MidPanel.AddNode(btnAct, i * ActBtnW, 0, ActBtnW - 2, MHeight * 0.12)
		MidPanel.AddNode(btnAct, i * ActBtnW, 0, ActBtnW - 2, MHeight * 0.05)
	Next

	' -------------------------------------------------------------
	' MDI Command Input Field Header banner
	' -------------------------------------------------------------
	Dim lblMdiHeader As Label
	lblMdiHeader.Initialize("")
	Dim xMdiH As B4XView = lblMdiHeader
	xMdiH.Text = " MDI - COMMAND ENTRY"
	xMdiH.Font = fx.CreateFont("Arial", 15, True, False)
	xMdiH.Color = COLOR_CNC_BLUE
	xMdiH.TextColor = xui.Color_White
	MidPanel.AddNode(lblMdiHeader, 0, MHeight * 0.15, W - 10, MHeight * 0.09)

	' -------------------------------------------------------------
	' Active Codes display line
	' -------------------------------------------------------------
	Dim lblActiveG As Label
	lblActiveG.Initialize("")
	lblActiveG.Text = "ACTIVE: G0|G17|G40|G49|G50|G54|G64|G69|G90|G94|G98"
	Dim xAG As B4XView = lblActiveG
	xAG.Font = fx.CreateFont("Courier New", 10, True, False)
	xAG.Color = 0xFF3399FF
	xAG.TextColor = xui.Color_White
	lblActiveG.Style = "-fx-padding: 2;"
	MidPanel.AddNode(lblActiveG, 0, MHeight * 0.24, W - 10, MHeight * 0.08)

	' @@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
	' -------------------------------------------------------------
	' G-Code Visual Trace Log console Window
	' -------------------------------------------------------------
	Dim txtConsole As TextArea
	txtConsole.Initialize("")
	MidPanel.AddNode(txtConsole, 0, MHeight * 0.35, (W - 10) * 0.60, MHeight * 0.60)
	Dim xCons As B4XView = txtConsole
	xCons.Text = "ACTUAL LINE" & CRLF & "0" & CRLF & CRLF & "(Profile: Dynamic Scaling Windows App Environment)"

	' -------------------------------------------------------------
	' Run from Here & Right-side auxiliary labels
	' -------------------------------------------------------------
	Dim btnRunHere As Button
	btnRunHere.Initialize("RunHere")
	Dim xRH As B4XView = btnRunHere
	xRH.Text = "Open COM"  ' "RUN FROM HERE"
	xRH.Font = fx.CreateFont("Arial", 10, True, False)
	xRH.Color = xui.Color_White
	btnRunHere.Style = "-fx-border-color: orange;"
	MidPanel.AddNode(btnRunHere, (W - 10) * 0.63, MHeight * 0.35, (W - 10) * 0.37, MHeight * 0.15)

	Dim lblDwell As Label
	lblDwell.Initialize("")
	lblDwell.Text = "DWELL TIME: 0" & CRLF & "TOOL IN USE: #1"
	Dim xDw As B4XView = lblDwell
	xDw.Font = fx.CreateFont("Arial", 11, False, False)
	MidPanel.AddNode(lblDwell, (W - 10) * 0.63, MHeight * 0.55, (W - 10) * 0.37, MHeight * 0.20)
End Sub
'================================================================================================================================
' -------------------------------------------------------------
' 6. Right Hand Control Deck (Tall Master Buttons stretched vertically)
' -------------------------------------------------------------
'

Sub CreateRightControlPanel(Parent As Pane, LeftOffset As Double, TopOffset As Double, W As Double, TotalHeight As Double)
	Dim RightPanel As Pane
	RightPanel.Initialize("")
	RightPanel.Style = "-fx-border-color: #A0A0A0; -fx-border-width: 0 0 0 1;"
	Parent.AddNode(RightPanel, LeftOffset, TopOffset + 5, W, TotalHeight - TopOffset - 10)

	Dim RHeight As Double = TotalHeight - TopOffset - 10
	Dim BtnW As Double = W - 15

	' -------------------------------------------------------------
	' 1st Button: Machine Offline Switch (Dark Gray Background, Yellow Border)
	' -------------------------------------------------------------
	Dim btnOffline As Button
	btnOffline.Initialize("ModeOffline")
	Dim xOff As B4XView = btnOffline
	xOff.Text = "OFFLINE" & CRLF & "MODE"
	xOff.Color = xui.Color_White
	' #5A5A5A is a robust, solid dark gray background color
	btnOffline.Style = "-fx-background-color: #5A5A5A; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: yellow; -fx-border-width: 2; -fx-text-alignment: center;"
	RightPanel.AddNode(btnOffline, 5, 0, BtnW, RHeight * 0.10)

	' -------------------------------------------------------------
	' 2nd Button: Cycle Start (Very Light Green Background, Green Border)
	' -------------------------------------------------------------
	Dim btnStart As Button
	btnStart.Initialize("ActionStart")
	Dim xStart As B4XView = btnStart
	xStart.Text = "CYCLE" & CRLF & "START"
	xStart.Font = fx.CreateFont("Arial", 14, True, False)
	xStart.Color = xui.Color_White
	xStart.TextColor = COLOR_CNC_GREEN
	' #E6F4EA is an ultra-clean, high-visibility light green tint
	btnStart.Style = "-fx-background-color: #E6F4EA; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #22B14C; -fx-border-width: 2.5; -fx-text-alignment: center;"
	RightPanel.AddNode(btnStart, 5, RHeight * 0.13, BtnW, RHeight * 0.15)

	' -------------------------------------------------------------
	' 3rd Button: Single Line Block (Very Light Yellow Background, Yellow Border)
	' -------------------------------------------------------------
	Dim btnSingle As Button
	btnSingle.Initialize("ModeSingle")
	Dim xSing As B4XView = btnSingle
	xSing.Text = "SINGLE" & CRLF & "LINE"
	xSing.Color = xui.Color_White
	' #FFFDE7 is a soft, industrial light yellow highlight tint
	btnSingle.Style = "-fx-background-color: #FFFDE7; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: yellow; -fx-border-width: 2; -fx-text-alignment: center;"
	RightPanel.AddNode(btnSingle, 5, RHeight * 0.30, BtnW, RHeight * 0.10)

	' -------------------------------------------------------------
	' 4th Button: Feed Hold (Very Light Yellow Background, Yellow Border)
	' -------------------------------------------------------------
	Dim btnHold As Button
	btnHold.Initialize("ActionHold")
	Dim xHold As B4XView = btnHold
	xHold.Text = "FEED" & CRLF & "HOLD"
	xHold.Font = fx.CreateFont("Arial", 14, True, False)
	xHold.Color = xui.Color_White
	xHold.TextColor = 0xFFE65100
	' Applied matching soft industrial light yellow tint (#FFFDE7) and yellow border
	btnHold.Style = "-fx-background-color: #FFFDE7; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: yellow; -fx-border-width: 2.5; -fx-text-alignment: center;"
	RightPanel.AddNode(btnHold, 5, RHeight * 0.42, BtnW, RHeight * 0.15)

	' -------------------------------------------------------------
	' 5th Button: Cycle Stop (Unchanged Standard Style Block)
	' -------------------------------------------------------------
	Dim btnStop As Button
	btnStop.Initialize("ActionStop")
	Dim xStop As B4XView = btnStop
	xStop.Text = "CYCLE" & CRLF & "STOP"
	xStop.Font = fx.CreateFont("Arial", 11, True, False)
	xStop.Color = xui.Color_White
	xStop.TextColor = COLOR_CNC_RED
	btnStop.Style = "-fx-background-color: white; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: red; -fx-border-width: 2; -fx-text-alignment: center;"
	RightPanel.AddNode(btnStop, 5, RHeight * 0.59, BtnW, RHeight * 0.12)

	' -------------------------------------------------------------
	' Last Button: Emergency RESET Switch (Solid Red Background, Yellow Border)
	' -------------------------------------------------------------
	Dim btnReset As Button
	btnReset.Initialize("ActionReset")
	Dim xReset As B4XView = btnReset
	xReset.Text = "RESET"
	xReset.Font = fx.CreateFont("Arial Black", 14, True, False)
	xReset.Color = COLOR_CNC_RED
	xReset.TextColor = xui.Color_White

	' UPDATED: Retained solid red background fill, replaced border rule with solid yellow
	btnReset.Style = "-fx-background-color: red; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: yellow; -fx-border-width: 2.5;"
	RightPanel.AddNode(btnReset, 5, (RHeight * 0.83) - 10, BtnW, RHeight * 0.16)

End Sub



