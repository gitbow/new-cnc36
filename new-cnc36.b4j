AppType=JavaFX
Build1=Default,b4j.example
Group=Default Group
Library1=javaobject
Library2=jcore
Library3=jfx
Library4=jserial
Library5=jxui
Library6=jrandomaccessfile
Module1=GcodePlotter
Module2=|relative|..\SerialCom
NumberOfFiles=0
NumberOfLibraries=6
NumberOfModules=2
Version=10.5
@EndOfDesignText@
#AdditionalJar: jSerial

Sub Process_Globals
	'Private sc As SerialCom
	Private xCons As B4XView   ' declare your text box here
	Private fx As JFX
	Private MainForm As Form
	Private xui As XUI
	Private Plotter As GcodePlotter
	Private Viewport1 As Pane
	' Colors matching the image
	Private COLOR_BG As Int = 0xFF3A3A3A
	Private COLOR_DARK_PANEL As Int = 0xFF000000
	Private COLOR_VIEWPORT2 As Int = 0xFF545454
	Private COLOR_CNC_BLUE As Int = 0xFF1B82D2
	Private COLOR_CNC_GREEN As Int = 0xFF22B14C
	Private COLOR_CNC_RED As Int = 0xFFED1C24
	
	Private GcodeListView As ListView
	Private CurrentGCodeLines As List
	Private UpdatingHighlight As Boolean = False
	
	Private sc As SerialCom
	Private statusTimer As Timer
	Private astream As AsyncStreams
	Private mCallback As Object
	
	
End Sub

Sub AppStart (Form1 As Form, Args() As String)
	MainForm = Form1
	MainForm.Title = "Precision CNC Controller"
    
	' Force the window canvas frame to completely fill the desktop natively
	Dim JoForm As JavaObject = MainForm
	JoForm.GetFieldJO("stage").RunMethod("setMaximized", Array(True))
    
	MainForm.Show
    
	' Trigger the layout drawer immediately after showing the window frame
	MainForm_Resize(MainForm.RootPane.Width, MainForm.RootPane.Height)
	'sc.Initialize
	sc.Initialize(Me)
	statusTimer.Initialize("statusTimer", 1000)   ' 1000 ms = 1 second

End Sub

Sub MainForm_Resize (Width As Double, Height As Double)
	' Guard against early execution errors before the window is ready
	If Width <= 0 Or Height <= 0 Then Return
    
	' Clean the canvas so elements don't duplicate on top of each other
	MainForm.RootPane.RemoveAllNodes
    
	' 🎛️ MARGIN ADJUSTMENT SETTING
	Dim EdgeMarginPercent As Double = 0.05
    
	' Dynamic positioning math based on active window size
	Dim StartX As Double = Width * (EdgeMarginPercent / 2)
	Dim StartY As Double = Height * (EdgeMarginPercent / 2)
	Dim TargetWidth As Double = Width * (1.0 - EdgeMarginPercent)
	Dim TargetHeight As Double = Height * (1.0 - EdgeMarginPercent)
    
	' Re-create the responsive main root pane zone inside the new dimensions
	Dim Root As Pane
	Root.Initialize("")
	MainForm.RootPane.AddNode(Root, StartX, StartY, TargetWidth, TargetHeight)
    
	Dim xRoot As B4XView = Root
	xRoot.Color = COLOR_BG
    
	' Calculate global fluid column widths based on current resolution
	Dim MenuHeight As Double = TargetHeight * 0.055
	Dim LeftToolbarWidth As Double = TargetWidth * 0.045
	Dim MainContentWidth As Double = TargetWidth - LeftToolbarWidth
    
	Dim Col1Width As Double = MainContentWidth * 0.40
	Dim Col2Width As Double = MainContentWidth * 0.46
	Dim Col3Width As Double = MainContentWidth * 0.14
    
	' Redraw all elements with the precise layout math
	CreateTopMenuBar(Root, TargetWidth, MenuHeight)
	CreateLeftToolbar(Root, LeftToolbarWidth, MenuHeight, TargetHeight)
	CreateViewportSection(Root, LeftToolbarWidth, MenuHeight, Col1Width, TargetHeight)
	CreateDroSection(Root, LeftToolbarWidth + Col1Width, MenuHeight, Col2Width, TargetHeight)
	CreateMdiAndFileSection(Root, LeftToolbarWidth + Col1Width, MenuHeight, Col2Width, TargetHeight)
	CreateRightControlPanel(Root, LeftToolbarWidth + Col1Width + Col2Width, MenuHeight, Col3Width, TargetHeight)
	' Link the plotter object instance to Viewport1 (which is the black pane)
	'Plotter.Initialize(MainForm, Viewport1)
	' Add this redraw call below your initialization line inside MainForm_Resize
	Plotter.Initialize(MainForm, Viewport1)
	Plotter.RefreshPlotterLayout
	' <-- Add this here to keep drawings visible during screen scaling

End Sub

' 1. Top Navigation Menu Bar (Fluid Width)
Sub CreateTopMenuBar(Parent As Pane, TotalWidth As Double, H As Double)
	Dim MenuItems() As String = Array As String("RUN", "TOOLPATH", "OFFSETS", "TOOLS", "CONFIGURATION", "DIAGNOSTICS", "CAM", "HELP")
	Dim ButtonWidth As Double = TotalWidth / MenuItems.Length
    
	For i = 0 To MenuItems.Length - 1
		Dim btn As Button
		btn.Initialize("MenuBtn")
		Dim xBtn As B4XView = btn
		xBtn.Text = MenuItems(i)
		xBtn.Font = fx.CreateFont("Arial", 12, True, False)
        
		If i = 0 Then
			xBtn.Color = COLOR_CNC_RED
			xBtn.TextColor = xui.Color_White
		Else
			xBtn.Color = xui.Color_White
			xBtn.TextColor = 0xFF555555
		End If
        
		btn.Style = "-fx-background-radius: 0; -fx-border-color: #A0A0A0; -fx-border-width: 1;"
		Parent.AddNode(btn, i * ButtonWidth, 0, ButtonWidth, H)
	Next
End Sub

' 2. Leftmost Vertical Tool Palette (Fluid Scaling)
Sub CreateLeftToolbar(Parent As Pane, W As Double, TopOffset As Double, TotalHeight As Double)
	Dim ToolPanel As Pane
	ToolPanel.Initialize("")
	Parent.AddNode(ToolPanel, 0, TopOffset, W, TotalHeight - TopOffset)
    
	' Add RESET button at the start
	Dim Icons() As String = Array As String("RESET", "Z_ALL", "Z_IN", "Z_OUT", "TOP", "FRONT", "SIDE", "ISO")
	Dim RowHeight As Double = (TotalHeight - TopOffset) / 12
    
	For i = 0 To Icons.Length - 1
		Dim btnIcon As Button
		btnIcon.Initialize("IconBtn")
		Dim xIcon As B4XView = btnIcon
		xIcon.Text = Icons(i)
		xIcon.Font = fx.CreateFont("Arial", 12, True, False)
		xIcon.Color = xui.Color_White
		xIcon.TextColor = xui.Color_Black
		btnIcon.Style = "-fx-border-color: #B0BEC5; -fx-border-radius: 2; -fx-background-radius: 2;"
		ToolPanel.AddNode(btnIcon, W * 0.1, 10 + (i * RowHeight), W * 0.8, RowHeight * 0.85)
	Next
End Sub

' 3. Dual Left-Center Viewports (Stretches to fill Left Half)
Sub CreateViewportSection(Parent As Pane, LeftOffset As Double, TopOffset As Double, W As Double, TotalHeight As Double)
	Dim UsableHeight As Double = TotalHeight - TopOffset
	Dim VP1Height As Double = UsableHeight * 0.52
	Dim VP2Height As Double = UsableHeight * 0.45
	Dim Gap As Double = UsableHeight * 0.02
    
	' Upper Primary 3D Workspace Simulator
	Viewport1.Initialize("")
	Dim xVP1 As B4XView = Viewport1
	xVP1.Color = COLOR_DARK_PANEL
	Viewport1.Style = "-fx-border-color: #707070; -fx-border-width: 2;"
	Parent.AddNode(Viewport1, LeftOffset + 5, TopOffset + 5, W - 10, VP1Height)
    
	' Lower G-Code Text Viewer (ListView instead of Pane)
	Dim lstGcode As ListView
	lstGcode.Initialize("lstGcode")
	Dim xList As B4XView = lstGcode
	xList.Color = COLOR_VIEWPORT2
	lstGcode.Style = "-fx-font-family: 'Courier New'; -fx-font-size: 12; -fx-border-color: #707070; -fx-border-width: 2;"
	Parent.AddNode(lstGcode, LeftOffset + 5, TopOffset + VP1Height + Gap, W - 10, VP2Height)
    
	' Store for later use
	GcodeListView = lstGcode
End Sub

' 4. Center-Right Panel Grid (DRO, Overrides, Offsets, MDI)
'

Sub CreateDroSection(Parent As Pane, LeftOffset As Double, TopOffset As Double, W As Double, TotalHeight As Double)
	' Top Main DRO Container
	Dim DroPanel As Pane
	DroPanel.Initialize("")
	DroPanel.Style = "-fx-border-color: #A0A0A0; -fx-border-width: 1; -fx-background-color: #EBEBEB;"
	Parent.AddNode(DroPanel, LeftOffset + 5, TopOffset + 5, W - 10, (TotalHeight - TopOffset) * 0.32)
    
	Dim DHeight As Double = (TotalHeight - TopOffset) * 0.32
    
	' Vertical Title Header Panel
	Dim lblTitle As Label
	lblTitle.Initialize("")
	lblTitle.Text = "M" & CRLF & "A" & CRLF & "C" & CRLF & "H" & CRLF & "I" & CRLF & "N" & CRLF & "E"
	lblTitle.Alignment = "CENTER"
	Dim xTitle As B4XView = lblTitle
	xTitle.Font = fx.CreateFont("Arial Narrow", 9, True, False)
	xTitle.Color = xui.Color_White
	xTitle.TextColor = COLOR_CNC_BLUE
	lblTitle.Style = "-fx-border-color: #1B82D2; -fx-border-width: 1;"
	DroPanel.AddNode(lblTitle, 2, 2, 22, DHeight - 6)
    
	' Zero All Master Button Group
	Dim btnZeroAll As Button
	btnZeroAll.Initialize("ZeroAll")
	Dim xZeroAll As B4XView = btnZeroAll
	xZeroAll.Text = "ZERO" & CRLF & "ALL"
	xZeroAll.Font = fx.CreateFont("Arial", 9, True, False)
	xZeroAll.Color = xui.Color_White
	xZeroAll.TextColor = COLOR_CNC_BLUE
	' UPDATED: Rounded corners added to Zero All button
	btnZeroAll.Style = "-fx-background-color: white; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1B82D2; -fx-border-width: 1; -fx-text-alignment: center;"
	DroPanel.AddNode(btnZeroAll, 26, 2, 45, DHeight - 6)
    
	' Complete Responsive Multi-Axis Rows Mapping (X, Y, Z, A, B, C)
	Dim Axes() As String = Array As String("X", "Y", "Z", "A", "B", "C")
	Dim Values() As String = Array As String("10.0000", "-49.4400", "-5.0000", "0.0000", "0.0000", "0.0000")
    
	Dim RowH As Double = (DHeight - 6) / Axes.Length
	Dim RemainderW As Double = W - 10 - 75
    
	For i = 0 To Axes.Length - 1
		Dim YPos As Double = i * RowH
        
		Dim btnZero As Button
		btnZero.Initialize("ZeroAxis")
		Dim xZero As B4XView = btnZero
		xZero.Text = "Ø"
		xZero.TextColor = COLOR_CNC_BLUE
		xZero.Color = xui.Color_White
		' UPDATED: Rounded corners added to individual Axis Zero buttons
		btnZero.Style = "-fx-background-color: white; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #A0A0A0; -fx-border-width: 1; -fx-padding: 0;"
		DroPanel.AddNode(btnZero, 75, YPos + 2, RemainderW * 0.06, RowH - 2)
        
		Dim lblAxis As Label
		lblAxis.Initialize("")
		lblAxis.Text = Axes(i)
		lblAxis.Alignment = "CENTER"
		Dim xAx As B4XView = lblAxis
		xAx.Font = fx.CreateFont("Arial", 12, True, False)
		xAx.TextColor = COLOR_CNC_BLUE
		lblAxis.Style = "-fx-border-color: #A0A0A0;"
		DroPanel.AddNode(lblAxis, 75 + (RemainderW * 0.06), YPos + 2, RemainderW * 0.06, RowH - 2)
        
		' Blue Rectangle Outline Pane around the Display Elements
		Dim pnlValueBorder As Pane
		pnlValueBorder.Initialize("")
		pnlValueBorder.Style = "-fx-background-color: transparent; -fx-border-color: #1B82D2; -fx-border-width: 1.5; -fx-border-radius: 4;"
		Dim BoxLeft As Double = 75 + (RemainderW * 0.12)
		Dim BoxWidth As Double = RemainderW * 0.78
		DroPanel.AddNode(pnlValueBorder, BoxLeft, YPos + 2, BoxWidth, RowH - 2)

		Dim lblScale As Label
		lblScale.Initialize("")
		lblScale.Text = "DTG 0.0" & CRLF & "Scale 1.0"
		Dim xScale As B4XView = lblScale
		xScale.Font = fx.CreateFont("Arial", 8, False, False)
		xScale.TextColor = COLOR_CNC_BLUE
		lblScale.Style = "-fx-padding: 0 0 0 4;"
		DroPanel.AddNode(lblScale, 75 + (RemainderW * 0.12), YPos + 2, RemainderW * 0.20, RowH - 2)
        
		Dim lblVal As Label
		lblVal.Initialize("")
		lblVal.Text = Values(i)
		lblVal.Alignment = "CENTER_RIGHT"
		Dim xVal As B4XView = lblVal
		xVal.Font = fx.CreateFont("Courier New", 18, True, False)
		xVal.TextColor = COLOR_CNC_BLUE
		lblVal.Style = "-fx-padding: 0 5 0 0;"
		DroPanel.AddNode(lblVal, 75 + (RemainderW * 0.32), YPos + 2, RemainderW * 0.58, RowH - 2)
        
		Dim btnHome As Button
		btnHome.Initialize("HomeAxis")
		Dim xHome As B4XView = btnHome
		xHome.Text = "🎯"
		xHome.Color = xui.Color_White
		' UPDATED: Rounded corners added to Axis Home buttons
		btnHome.Style = "-fx-background-color: white; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: red; -fx-border-width: 1; -fx-padding: 0;"
		DroPanel.AddNode(btnHome, 75 + (RemainderW * 0.90), YPos + 2, RemainderW * 0.09, RowH - 2)
	Next
End Sub


